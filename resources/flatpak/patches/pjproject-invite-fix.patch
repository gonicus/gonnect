diff --git a/pjsip/src/pjsip-ua/sip_inv.c b/pjsip/src/pjsip-ua/sip_inv.c
index a373b8f..0dcd02b 100644
--- a/pjsip/src/pjsip-ua/sip_inv.c
+++ b/pjsip/src/pjsip-ua/sip_inv.c
@@ -4908,6 +4908,28 @@ static pj_bool_t handle_uac_tsx_response(pjsip_inv_session *inv,
              * within dialog. And even if we terminate we should
              * send BYE.
              */
+            if (status != PJ_SUCCESS &&
+                tsx->method.id == PJSIP_INVITE_METHOD &&
+                inv->neg &&
+                pjmedia_sdp_neg_get_state(inv->neg) ==
+                    PJMEDIA_SDP_NEG_STATE_LOCAL_OFFER)
+            {
+                /* The INVITE will not be retried (e.g. 401 with
+                 * stale=false), so nothing will ever answer the offer it
+                 * carried. Cancel it here, because no other code path
+                 * will: we return PJ_TRUE below, which makes
+                 * inv_on_state_confirmed() take its "already handled"
+                 * branch instead of the generic >= 300 handling, and once
+                 * the tsx moves COMPLETED -> TERMINATED that handling is
+                 * excluded by the prev_state guard (see #1654).
+                 *
+                 * Leaving the negotiator in LOCAL_OFFER bricks the dialog:
+                 * every subsequent outgoing re-INVITE silently reuses the
+                 * stale offer, and every incoming re-INVITE is answered
+                 * with 491 Request Pending.
+                 */
+                pjmedia_sdp_neg_cancel_offer(inv->neg);
+            }
         }
 
         return PJ_TRUE; /* Handled */
